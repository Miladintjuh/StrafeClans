<UserControl x:Class="StrafeLab.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Profile" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Text="Your cloud profile and synced StrafeLab summaries." Style="{StaticResource Muted}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Margin="0,0,8,0" />
                <Button x:Name="SignOutButton" Content="Sign out" Click="SignOutButton_Click" Background="#29324A" Margin="0,0,8,0" />
                <Button Content="Back" Click="BackButton_Click" Background="#29324A" />
            </StackPanel>
        </Grid>

        <Border x:Name="PrivacyChoicePanel" Grid.Row="1" Style="{StaticResource Card}" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Choose profile visibility" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Profiles are private by default. Public profiles can be opened from clan rankings; private profiles cannot be clicked by other players." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Keep private" Click="KeepPrivateButton_Click" Background="#29324A" Margin="0,0,8,0" />
                    <Button Content="Make public" Click="MakePublicButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Account" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="IdentityText" Text="Loading..." FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <TextBlock x:Name="VisibilityText" Text="Visibility: private" Style="{StaticResource Muted}" Margin="0,4,0,6" />
                    <TextBlock x:Name="VisibilityPromptText" Text="Choose whether other clan members can open your profile from ranking lists. Private is the default." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <WrapPanel>
                        <Button x:Name="SetPrivateButton" Content="Keep private" Click="SetPrivateButton_Click" Background="#29324A" Margin="0,0,8,8" />
                        <Button x:Name="SetPublicButton" Content="Make public" Click="SetPublicButton_Click" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Sync reassurance" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Only session summary numbers are uploaded: attempts, clean count, moving shots, overlap/slow counts, and averages. Raw key edges, raw mouse traces, and exported CSV files stay local on your PC." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    <TextBlock Text="Private profiles cannot be opened from leaderboards. Clan owners can still see aggregated clan stats needed for team practice." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="4" Margin="0,8,0,0">
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Sessions" Style="{StaticResource Muted}"/><TextBlock x:Name="SessionsText" Text="0" Style="{StaticResource MetricValue}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Attempts" Style="{StaticResource Muted}"/><TextBlock x:Name="AttemptsText" Text="0" Style="{StaticResource MetricValue}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Clean rate" Style="{StaticResource Muted}"/><TextBlock x:Name="CleanRateText" Text="0%" Style="{StaticResource MetricValue}" Foreground="{StaticResource GoodBrush}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Moving rate" Style="{StaticResource Muted}"/><TextBlock x:Name="MovingRateText" Text="0%" Style="{StaticResource MetricValue}" Foreground="{StaticResource WarnBrush}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Clean" Style="{StaticResource Muted}"/><TextBlock x:Name="CleanText" Text="0" Style="{StaticResource MetricValue}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Moving" Style="{StaticResource Muted}"/><TextBlock x:Name="MovingText" Text="0" Style="{StaticResource MetricValue}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Avg counter" Style="{StaticResource Muted}"/><TextBlock x:Name="CounterText" Text="0 ms" Style="{StaticResource MetricValue}"/></StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Avg click" Style="{StaticResource Muted}"/><TextBlock x:Name="ClickText" Text="0 ms" Style="{StaticResource MetricValue}"/></StackPanel></Border>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>
