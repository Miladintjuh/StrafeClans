<UserControl x:Class="StrafeLab.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#08101E" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="8,6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="#131B30" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Reports" FontSize="34" FontWeight="Bold" />
                <TextBlock Text="Build a focused report by dragging data blocks into the report layout." Style="{StaticResource Muted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Generate preview" Click="GenerateButton_Click" Margin="0,0,8,0" />
                <Button Content="Copy report" Click="CopyButton_Click" Background="#29324A" Margin="0,0,8,0" />
                <Button Content="Back" Click="BackButton_Click" Background="#29324A" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Block library" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Drag blocks into the report. Double-click also adds a block." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                    <ListBox x:Name="LibraryList" Grid.Row="1" PreviewMouseMove="LibraryList_PreviewMouseMove" MouseDoubleClick="LibraryList_MouseDoubleClick" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Report layout" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Drop blocks here. Use the arrows to reorder and remove sections you do not need." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                    <ListBox x:Name="ReportList" Grid.Row="1" AllowDrop="True" Drop="ReportList_Drop" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="↑" Width="42" Click="MoveUpButton_Click" Background="#29324A" Margin="0,0,8,0" />
                        <Button Content="↓" Width="42" Click="MoveDownButton_Click" Background="#29324A" Margin="0,0,8,0" />
                        <Button Content="Remove" Click="RemoveBlockButton_Click" Background="#29324A" Margin="0,0,8,0" />
                        <Button Content="Clear" Click="ClearBlocksButton_Click" Background="#29324A" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Preview" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="The preview uses the current included attempts and updates when you generate." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                    <TextBox x:Name="PreviewBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
