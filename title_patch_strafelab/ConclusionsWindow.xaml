<Window x:Class="StrafeLab.ConclusionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StrafeLab Conclusions" Height="930" Width="1360" MinHeight="760" MinWidth="1120">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="SmallLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SoftBrush}" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Session conclusions" FontSize="32" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Text="Included attempts only. Jiggles and manually excluded rows are ignored." Style="{StaticResource Muted}" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Click="CloseButton_Click" Background="#29324A" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Attempts analyzed" Style="{StaticResource SmallLabel}" />
                    <TextBlock x:Name="AttemptsMetricText" Text="0" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="TraceMetricText" Text="0 mouse traces" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Main timing issue" Style="{StaticResource SmallLabel}" />
                    <TextBlock x:Name="TimingIssueMetricText" Text="-" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="TimingIssueDetailText" Text="No timing data yet" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Direction bias" Style="{StaticResource SmallLabel}" />
                    <TextBlock x:Name="DirectionBiasMetricText" Text="-" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="DirectionBiasDetailText" Text="A>D and D>A are balanced" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Aim path quality" Style="{StaticResource SmallLabel}" />
                    <TextBlock x:Name="AimQualityMetricText" Text="-" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="AimQualityDetailText" Text="No mouse traces yet" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="2" Margin="8,10,8,0">
            <TabItem Header="Timing">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.75*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Counter-strafe timing distribution" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Negative buckets are overlap. Positive buckets are late counter input. The shaded target band is the configured ideal window." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="TimingCanvas" Background="#08101E" MinHeight="420" />
                            </Border>
                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                <TextBlock Text="Legend:" Style="{StaticResource Muted}" Margin="0,0,12,0" />
                                <TextBlock Text="Overlap" Foreground="#FF5C7A" Margin="0,0,16,0" />
                                <TextBlock Text="Late" Foreground="#00E0FF" Margin="0,0,16,0" />
                                <TextBlock Text="Clean" Foreground="#FFCE45" Margin="0,0,16,0" />
                                <TextBlock Text="Early click" Foreground="#B18CFF" Margin="0,0,16,0" />
                                <TextBlock Text="Missed" Foreground="#A8B0C8" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="How to read this" Style="{StaticResource CardTitle}" />
                                <TextBlock x:Name="TimingInsightText" Text="No timing insight yet." TextWrapping="Wrap" FontSize="15" LineHeight="23" Margin="0,10,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Direction compare">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="A>D vs D>A result mix" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Each horizontal bar is 100% of that direction. Results are separate from mistakes: overlap and slow timing are still listed in the notes." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="DirectionRateCanvas" Background="#08101E" MinHeight="420" />
                            </Border>
                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                <TextBlock Text="Accurate" Foreground="#38D996" Margin="0,0,12,0" />
                                <TextBlock Text="Moving" Foreground="#FFCE45" Margin="0,0,12,0" />
                                <TextBlock Text="Inaccurate" Foreground="#FF5C7A" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Average counter delay" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Compares whether one direction consistently arrives later or overlaps more." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="DirectionDelayCanvas" Background="#08101E" MinHeight="190" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Directional aim quality" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Path efficiency by movement direction. Higher means cleaner, straighter movement." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="DirectionAimCanvas" Background="#08101E" MinHeight="190" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Direction diagnosis" Style="{StaticResource CardTitle}" />
                                <TextBlock x:Name="DirectionInsightText" Text="No direction insight yet." TextWrapping="Wrap" FontSize="15" LineHeight="23" Margin="0,10,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Mouse / aim">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.25*" />
                        <RowDefinition Height="0.95*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Mouse reaction map" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Each dot is an attempt. X = click timing after counter key. Y = path efficiency. Try to move dots into the bright target zone: clean path + click in your configured window." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="AimCanvas" Background="#08101E" MinHeight="480" />
                            </Border>
                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                <TextBlock Text="Single line" Foreground="#38D996" Margin="0,0,16,0" />
                                <TextBlock Text="Micro-adjust" Foreground="#FFCE45" Margin="0,0,16,0" />
                                <TextBlock Text="Overflick" Foreground="#FF5C7A" Margin="0,0,16,0" />
                                <TextBlock Text="Messy" Foreground="#B18CFF" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Path type breakdown" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Shows whether misses are more likely straight flicks, controlled micro-corrections, overflicks, or messy paths." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="AimBreakdownCanvas" Background="#08101E" MinHeight="220" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="What the map means" Style="{StaticResource CardTitle}" />
                                <TextBlock x:Name="AimInsightText" Text="No aim insight yet." TextWrapping="Wrap" FontSize="15" LineHeight="23" Margin="0,10,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Consistency">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Counter timing over the session" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Shows drift, warm-up problems, and fatigue. The shaded band is the ideal counter-key timing window." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="ConsistencyCanvas" Background="#08101E" MinHeight="260" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Click timing after counter" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Shows whether shots happen before your hand/mouse settles or too late after the counter key." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="ReactionConsistencyCanvas" Background="#08101E" MinHeight="230" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Outlier finder" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="Large dots are the attempts most worth reviewing in the main trace overlay." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="OutlierCanvas" Background="#08101E" MinHeight="230" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Consistency diagnosis" Style="{StaticResource CardTitle}" />
                                <TextBlock x:Name="ConsistencyInsightText" Text="No consistency insight yet." TextWrapping="Wrap" FontSize="15" LineHeight="23" Margin="0,10,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Coaching">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Recommended focus" Style="{StaticResource CardTitle}" />
                            <TextBlock x:Name="ConclusionsText" Text="No conclusions yet." TextWrapping="Wrap" FontSize="16" LineHeight="26" Margin="0,12,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
