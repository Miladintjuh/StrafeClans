<Application x:Class="StrafeLab.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <Color x:Key="Bg0">#0B1020</Color>
        <Color x:Key="Bg1">#11182C</Color>
        <Color x:Key="Bg2">#172036</Color>
        <Color x:Key="Accent">#7C5CFF</Color>
        <Color x:Key="Accent2">#00E0FF</Color>
        <Color x:Key="Good">#38D996</Color>
        <Color x:Key="Warn">#FFCE45</Color>
        <Color x:Key="Bad">#FF5C7A</Color>
        <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource Bg0}" />
        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource Bg0}" />
        <!-- Compatibility alias used by the one-window mode host. -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Bg0}" />
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Bg1}" />
        <SolidColorBrush x:Key="SoftBrush" Color="{StaticResource Bg2}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2}" />
        <SolidColorBrush x:Key="TextBrush" Color="#F5F7FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8B0C8" />
        <SolidColorBrush x:Key="BorderBrush" Color="#26304A" />
        <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource Good}" />
        <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource Warn}" />
        <SolidColorBrush x:Key="BadBrush" Color="{StaticResource Bad}" />
        <SolidColorBrush x:Key="StepLeftBrush" Color="{StaticResource Accent2}" />
        <SolidColorBrush x:Key="StepRightBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="SprayBrush" Color="{StaticResource Warn}" />
        <SolidColorBrush x:Key="TraceHighlightBrush" Color="{StaticResource Accent2}" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WindowBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="8" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3F4E" />
                    <Setter Property="Foreground" Value="#A8B0C8" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.46" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </Application.Resources>
</Application>
