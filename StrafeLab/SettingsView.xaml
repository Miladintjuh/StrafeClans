<UserControl x:Class="StrafeLab.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="InfoIcon" TargetType="TextBlock">
            <Setter Property="Text" Value="ⓘ" />
            <Setter Property="Foreground" Value="{StaticResource Accent2Brush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Help" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,14,10" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Settings" FontSize="34" FontWeight="Bold" />
                <TextBlock Text="Adjust calibration, judgment windows, hotkeys, visible columns, and all app colors." Style="{StaticResource Muted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ShowDemoButton" Content="Show me the demo" Click="ShowDemoButton_Click" Background="#29324A" Margin="0,0,8,0" />
                <Button Content="Apply" Click="ApplyButton_Click" Margin="0,0,8,0" />
                <Button Content="Back" Click="BackButton_Click" Background="#29324A" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="CalibrationCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Game calibration" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoIcon}" ToolTip="Used to convert raw mouse counts into estimated degrees and cm/360. This does not change captured input." />
                            </StackPanel>
                            <TextBlock Text="Enter your in-game values so mouse movement metrics use meaningful units." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="128" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="DPI"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Your mouse DPI. Used for cm/360 calculation. Default: 1600."/></StackPanel><TextBox Grid.Row="0" Grid.Column="1" x:Name="DpiBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Sensitivity"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Your in-game sensitivity. Default: 0.4."/></StackPanel><TextBox Grid.Row="1" Grid.Column="1" x:Name="SensBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Yaw"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Horizontal degrees per raw mouse count at sensitivity 1.0. CS default: 0.022."/></StackPanel><TextBox Grid.Row="2" Grid.Column="1" x:Name="YawBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Pitch"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Vertical degrees per raw mouse count at sensitivity 1.0. CS default: 0.022."/></StackPanel><TextBox Grid.Row="3" Grid.Column="1" x:Name="PitchBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,10,0"><TextBlock Text="Multiplier"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Optional sensitivity multiplier. Leave 1.0 for normal hipfire practice."/></StackPanel><TextBox Grid.Row="4" Grid.Column="1" x:Name="MultiplierBox"/>
                            </Grid>
                            <TextBlock x:Name="CalibrationPreviewText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,14,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Timing judgment" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoIcon}" ToolTip="These values decide whether attempts are clean, slow, overlap, early, moving, or inaccurate." />
                            </StackPanel>
                            <TextBlock Text="Counter-strafe and click windows used by the trainer, analytics, and reports." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="128" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Counter min"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Minimum acceptable release-to-counter delay. Smaller values may be overlap unless inside HE tolerance."/></StackPanel><TextBox Grid.Row="0" Grid.Column="1" x:Name="CounterMinBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Counter max"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Maximum acceptable release-to-counter delay. Higher values are labeled slow/late."/></StackPanel><TextBox Grid.Row="1" Grid.Column="1" x:Name="CounterMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Click min"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Minimum acceptable counter-to-click delay. Lower values are labeled early shot."/></StackPanel><TextBox Grid.Row="2" Grid.Column="1" x:Name="ClickMinBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Click max"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Maximum useful counter-to-click delay. Higher values are slow shots."/></StackPanel><TextBox Grid.Row="3" Grid.Column="1" x:Name="ClickMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="HE tolerance"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Hall-effect/rapid-trigger tolerance in ms. Tiny overlaps inside this tolerance are not treated as real mistakes."/></StackPanel><TextBox Grid.Row="4" Grid.Column="1" x:Name="KeyboardOverlapToleranceBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Clean fast max"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Clean attempts with total time at or below this are labeled fast clean in What happened."/></StackPanel><TextBox Grid.Row="5" Grid.Column="1" x:Name="CleanFastMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Clean perfect max"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Clean attempts above fast max and at or below this are labeled perfect clean."/></StackPanel><TextBox Grid.Row="6" Grid.Column="1" x:Name="CleanPerfectMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,10,0"><TextBlock Text="Just-in-time min"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Clean attempts at or above this total time, but still inside the clean window, are labeled just-in-time clean."/></StackPanel><TextBox Grid.Row="7" Grid.Column="1" x:Name="CleanJustInTimeMinBox"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Peek mode" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoIcon}" ToolTip="Peek-mode specific timing and shot-pattern settings. These are removed from the live Peek screen to keep practice uncluttered." />
                            </StackPanel>
                            <TextBlock Text="Settings used by the 5e_aimhub Peek mode." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="210" /><ColumnDefinition Width="128" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Clean max"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Peek mode clean timing upper bound for release-to-counter delay."/></StackPanel><TextBox Grid.Row="0" Grid.Column="1" x:Name="PeekCleanMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Overlap tol"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Peek mode overlap tolerance. Negative delays inside this window can still be treated as usable."/></StackPanel><TextBox Grid.Row="1" Grid.Column="1" x:Name="PeekOverlapToleranceBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Spray hold"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="M1 hold duration in ms that is treated as a spray hold in Peek mode."/></StackPanel><TextBox Grid.Row="2" Grid.Column="1" x:Name="PeekSprayHoldBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Max mouse ms"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Safety cap: stop recording a Peek rep's mouse trace after this many ms from step-out."/></StackPanel><TextBox Grid.Row="3" Grid.Column="1" x:Name="PeekMouseTraceMaxBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Max trace points"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Safety cap: maximum mouse points kept per Peek activation. Lower this if Peek mode lags."/></StackPanel><TextBox Grid.Row="4" Grid.Column="1" x:Name="PeekMouseTracePointsBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,10,0"><TextBlock Text="Stop after click"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Stop adding mouse movement this many ms after first M1 if the reset movement has not happened yet."/></StackPanel><TextBox Grid.Row="5" Grid.Column="1" x:Name="PeekResetAfterClickBox"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Hotkeys and display" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource InfoIcon}" ToolTip="Changing hotkeys re-registers them after Apply. Avoid single-letter keys if they interfere with normal gameplay." />
                            </StackPanel>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="132" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Start/stop"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Click Record, then press the key you want to use globally."/></StackPanel><Button Grid.Row="0" Grid.Column="1" x:Name="StartStopHotkeyButton" Click="RecordHotkeyButton_Click" Tag="StartStop" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Arm peek rep"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Click Record, then press the key for one Peek rep."/></StackPanel><Button Grid.Row="1" Grid.Column="1" x:Name="PeekHotkeyButton" Click="RecordHotkeyButton_Click" Tag="Peek" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Remove latest"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Click Record, then press the key to remove the latest normal attempt."/></StackPanel><Button Grid.Row="2" Grid.Column="1" x:Name="RemoveHotkeyButton" Click="RecordHotkeyButton_Click" Tag="Remove" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Default traces"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Default number of recent mouse traces drawn in the overlay."/></StackPanel><TextBox Grid.Row="3" Grid.Column="1" x:Name="DefaultTraceCountBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,10,10"><TextBlock Text="Switch while live"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Controls what happens when you switch between the main trainer and Peek mode while a session is recording."/></StackPanel><ComboBox Grid.Row="4" Grid.Column="1" x:Name="ModeSwitchChoiceBox" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="5" Grid.ColumnSpan="2">
                                    <CheckBox x:Name="ShowAdvancedFiltersCheckBox" Content="Show advanced attempt filters" />
                                    <CheckBox x:Name="PlaySoundsCheckBox" Content="Play hotkey audio indicators" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Recent-attempt columns" FontSize="20" FontWeight="SemiBold"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Choose which columns appear in the normal counter-strafe attempts table."/></StackPanel>
                            <WrapPanel Margin="0,14,0,0">
                                <CheckBox x:Name="UseColumnCheckBox" Content="Use" Visibility="Collapsed"/><CheckBox x:Name="IndexColumnCheckBox" Content="#"/><CheckBox x:Name="DirectionColumnCheckBox" Content="Direction"/><CheckBox x:Name="CounterDelayColumnCheckBox" Content="Key wait"/><CheckBox x:Name="ClickDelayColumnCheckBox" Content="Click wait"/><CheckBox x:Name="MistakesColumnCheckBox" Content="Mistakes"/><CheckBox x:Name="ResultColumnCheckBox" Content="Result"/><CheckBox x:Name="WhatHappenedColumnCheckBox" Content="What happened"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Local data" FontSize="20" FontWeight="SemiBold"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Open the local folder where StrafeLab saves sessions, CSV exports, and preferences."/></StackPanel>
                            <Button Content="Open data folder" Click="OpenDataFolderButton_Click" Background="#29324A" Padding="14,9" HorizontalAlignment="Left" Margin="0,14,0,0" />
                            <TextBlock Text="Saved sessions are stored under %LOCALAPPDATA%\StrafeLab\sessions." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Colors" FontSize="20" FontWeight="SemiBold"/><TextBlock Style="{StaticResource InfoIcon}" ToolTip="Every main color used by the app. Edit a hex value or use the picker next to that color. Test is temporary; Apply saves."/></StackPanel>
                            <TextBlock Text="Changing app colors may require a reload before every screen reflects the new palette. Invalid values fall back to the previous safe color." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,12" />
                            <WrapPanel Margin="0,4,0,0">
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="App background" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorWindowBackgroundBox" Width="108"/><Button Width="32" Content="🎨" Tag="WindowBackground" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4" ToolTip="Pick app/window background color"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Page background" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorBackgroundBox" Width="108"/><Button Width="32" Content="🎨" Tag="Background" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4" ToolTip="Pick page/content background color"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Card" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorCardBox" Width="108"/><Button Width="32" Content="🎨" Tag="Card" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Surface" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorSurfaceBox" Width="108"/><Button Width="32" Content="🎨" Tag="Surface" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Accent" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorAccentBox" Width="108"/><Button Width="32" Content="🎨" Tag="Accent" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Accent alt" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorAccentAltBox" Width="108"/><Button Width="32" Content="🎨" Tag="AccentAlt" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Text" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorTextBox" Width="108"/><Button Width="32" Content="🎨" Tag="Text" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Muted text" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorMutedTextBox" Width="108"/><Button Width="32" Content="🎨" Tag="MutedText" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Border" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorBorderBox" Width="108"/><Button Width="32" Content="🎨" Tag="Border" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Good" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorGoodBox" Width="108"/><Button Width="32" Content="🎨" Tag="Good" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Warning" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorWarningBox" Width="108"/><Button Width="32" Content="🎨" Tag="Warning" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Bad" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorBadBox" Width="108"/><Button Width="32" Content="🎨" Tag="Bad" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Step left" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorStepLeftBox" Width="108"/><Button Width="32" Content="🎨" Tag="StepLeft" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Step right" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorStepRightBox" Width="108"/><Button Width="32" Content="🎨" Tag="StepRight" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Spray" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorSprayBox" Width="108"/><Button Width="32" Content="🎨" Tag="Spray" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                                <StackPanel Width="182" Margin="0,0,14,10"><TextBlock Text="Trace highlight" Style="{StaticResource Muted}"/><StackPanel Orientation="Horizontal"><TextBox x:Name="ColorTraceHighlightBox" Width="108"/><Button Width="32" Content="🎨" Tag="TraceHighlight" Click="ColorButton_Click" Margin="6,0,0,0" Padding="4"/></StackPanel></StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Popup x:Name="ColorPickerPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" Closed="ColorPickerPopup_Closed">
                <Border Width="330" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="14">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock x:Name="ColorPickerTitleText" Text="Pick color" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                            <Button Content="×" Click="CloseColorPickerButton_Click" DockPanel.Dock="Right" Background="#29324A" Padding="10,5" />
                        </DockPanel>
                        <TextBlock Text="Use RGB sliders or enter a hex color. Test is temporary; Apply saves and prompts for reload." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,10" />
                        <Border x:Name="ColorPickerPreview" Height="54" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10" />
                        <TextBox x:Name="ColorPickerHexBox" TextChanged="ColorPickerHexBox_TextChanged" Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="R" Grid.Row="0" Style="{StaticResource Muted}" VerticalAlignment="Center"/><Slider x:Name="RedSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_ValueChanged"/>
                            <TextBlock Text="G" Grid.Row="1" Style="{StaticResource Muted}" VerticalAlignment="Center"/><Slider x:Name="GreenSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_ValueChanged"/>
                            <TextBlock Text="B" Grid.Row="2" Style="{StaticResource Muted}" VerticalAlignment="Center"/><Slider x:Name="BlueSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="ColorSlider_ValueChanged"/>
                        </Grid>
                        <TextBlock x:Name="ColorPickerStatusText" Text="" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <Button Content="Test" Click="TestColorButton_Click" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>
