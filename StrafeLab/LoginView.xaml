<UserControl x:Class="StrafeLab.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="AccountTitleText" Text="Welcome to StrafeLab" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="AccountSubtitleText" Text="Create an online profile to save CS2 practice stats, join clans, and compare your progress. Local-only is available if you just want to train on this PC." Style="{StaticResource Muted}" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" x:Name="BackButton" Content="Back" Click="BackButton_Click" Background="#29324A" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.08*" />
                    <ColumnDefinition Width="0.92*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource Card}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.6">
                        <StackPanel>
                            <TextBlock Text="Online profile — recommended" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Use this for synced summaries, clans, profile stats, and progress that survives local resets. No email is needed to start." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16" />

                            <TextBlock Text="Username" Style="{StaticResource Muted}" />
                            <TextBox x:Name="UsernameBox" Margin="0,4,0,12" ToolTip="Allowed: letters, numbers, underscore, dot. Friends use this to invite you." />

                            <TextBlock Text="Password" Style="{StaticResource Muted}" />
                            <PasswordBox x:Name="PasswordBox" Margin="0,4,0,18" KeyDown="PasswordBox_KeyDown" />

                            <WrapPanel>
                                <Button x:Name="CreateButton" Content="Create online profile" Click="CreateButton_Click" Margin="0,0,8,8" />
                                <Button x:Name="SignInButton" Content="Sign in" Click="SignInButton_Click" Background="#29324A" Margin="0,0,8,8" />
                                <Button x:Name="SignOutButton" Content="Sign out" Click="SignOutButton_Click" Background="#29324A" Margin="0,0,8,8" />
                            </WrapPanel>

                            <TextBlock x:Name="StatusText" Text="Create or sign in with username and password." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,14,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Local-only" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Use StrafeLab without an account. Raw inputs, traces, and summaries stay on this PC. Clans and synced progress are disabled." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,12" />
                            <Button x:Name="FullOptOutButton" Content="Continue local-only" Click="FullOptOutButton_Click" HorizontalAlignment="Left" Background="#29324A" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Train cleaner counter-strafes" FontSize="26" FontWeight="Bold" />
                        <TextBlock Text="StrafeLab turns your A/D timing, first-shot discipline, and mouse movement into a clear practice plan." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,18" />

                        <TextBlock Text="See every attempt" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,4" />
                        <TextBlock Text="Every rep is listed with direction, counter delay, click delay, mistakes, and a short explanation." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />

                        <TextBlock Text="Replay the exact key order" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <TextBlock Text="Select an attempt and watch A, D, and M1 in slow motion. This is the fastest way to understand why a shot was clean, late, or moving." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />

                        <TextBlock Text="Connect aim and movement" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <TextBlock Text="Mouse traces show how much your crosshair moved between the counter-strafe and the shot, so you can spot rushed corrections and messy sprays." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14" />

                        <TextBlock Text="Leave with a short practice plan" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <TextBlock Text="Conclusions turn the session into specific drills: stop before shooting, fix one direction, reduce overlap, or clean up mouse corrections." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
