<UserControl x:Class="StrafeLab.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="AccountTitleText" Text="Choose how you want to use StrafeLab" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="AccountSubtitleText" Text="Choose how you want to use StrafeLab." Style="{StaticResource Muted}" />
            </StackPanel>
            <Button x:Name="BackButton" Grid.Column="1" Content="Back" Click="BackButton_Click" Background="#29324A" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Border Background="{StaticResource SoftBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Choose your privacy option" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Share non-personal practice summaries such as hits, misses, timings and session results to help improve StrafeLab." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,12" />
                                <TextBlock Text="Display name" Style="{StaticResource Muted}" />
                                <TextBox x:Name="AnonymousNameBox" Margin="0,4,0,12" ToolTip="Used to group your summary stats. Allowed: letters, numbers, underscore, dot." />
                                <Button x:Name="ShareStatsButton" Content="Continue with shared practice summaries" Click="ShareStatsButton_Click" HorizontalAlignment="Left" />
                                <Button x:Name="FullOptOutButton" Content="No, fuck off, collect some sand instead of my NON PERSONALIZED data" Click="FullOptOutButton_Click" HorizontalAlignment="Left" Background="#29324A" Margin="0,8,0,0" ToolTip="Use StrafeLab locally only. No account, no anonymous stats sharing, no cloud sync." />
                                <TextBlock Text="You can change your mind later by creating or signing in to an account." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Or sign in with an account" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Use an account if you want your profile, clans and team dashboard progress to carry over between sessions." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,18" />

                        <TextBlock Text="Email" Style="{StaticResource Muted}" />
                        <TextBox x:Name="EmailBox" Margin="0,4,0,12" />

                        <TextBlock Text="Password" Style="{StaticResource Muted}" />
                        <PasswordBox x:Name="PasswordBox" Margin="0,4,0,12" KeyDown="PasswordBox_KeyDown" />

                        <TextBlock Text="Username for new accounts" Style="{StaticResource Muted}" />
                        <TextBox x:Name="UsernameBox" Margin="0,4,0,18" ToolTip="Used by friends to invite you. Allowed: letters, numbers, underscore, dot." />

                        <WrapPanel>
                            <Button x:Name="SignInButton" Content="Sign in" Click="SignInButton_Click" Margin="0,0,8,8" />
                            <Button x:Name="CreateButton" Content="Create account" Click="CreateButton_Click" Background="#29324A" Margin="0,0,8,8" />
                            <Button x:Name="SignOutButton" Content="Sign out" Click="SignOutButton_Click" Background="#29324A" Margin="0,0,8,8" />
                        </WrapPanel>

                        <TextBlock x:Name="StatusText" Text="Not signed in." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,14,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="What gets shared" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Only saved session summaries are uploaded: attempts, clean shots, moving shots, overlaps, slow counters and average timing values." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,14" />
                        <TextBlock Text="What stays local" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <TextBlock Text="Raw keyboard events, raw mouse movement, mouse traces, screenshots and exported CSV files stay on your PC. They are not uploaded by StrafeLab." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        <TextBlock Text="Privacy defaults" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <TextBlock Text="Profiles start private. You decide whether other clan members can open your profile from leaderboards. You can change this later from your profile page." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        <TextBlock Text="For new users" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,4" />
                        <TextBlock Text="StrafeLab is a practice tool. The shared stats are meant to help improve the app and compare practice progress." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                        <TextBlock Text="Need help?" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,4" />
                        <TextBlock Text="Ask the StrafeLab owner if account or clan features are not available yet." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
