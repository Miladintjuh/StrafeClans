<Window x:Class="StrafeLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StrafeLab" Icon="Assets/StrafeLab.ico" Height="940" Width="1500" MinHeight="820" MinWidth="1220" Background="{StaticResource WindowBgBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SmallLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#10172A" />
            <Setter Property="AlternatingRowBackground" Value="#131B30" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182139" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2B3B63" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderChrome" Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="StrafeLab" FontSize="34" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="StartButton" Content="Start [F9]" Click="StartButton_Click" Margin="0,0,8,0" />
                <Button x:Name="StopButton" Content="Stop + Save [F9]" Click="StopButton_Click" Background="#29324A" Margin="0,0,8,0" Visibility="Collapsed" />
                <Button x:Name="ReportsButton" Content="Reports" Click="ReportsButton_Click" Background="#29324A" Margin="0,0,8,0" IsEnabled="False" ToolTip="Record at least one included attempt before building a report." />
                <Button x:Name="AccountButton" Content="Login" Click="AccountButton_Click" Background="#29324A" Margin="0,0,8,0" ToolTip="Sign in or create an account." />
                <Button x:Name="ClansButton" Content="Clans" Click="ClansButton_Click" Background="#29324A" Margin="0,0,8,0" IsEnabled="False" ToolTip="Sign in to view clan stats." />
                <Button x:Name="AdminButton" Content="Admin" Click="AdminButton_Click" Background="#29324A" Margin="0,0,8,0" Visibility="Collapsed" IsEnabled="False" ToolTip="Admin/moderator access only." />
                <Button x:Name="PeekButton" Content="Peek mode [F8]" Click="PeekModeButton_Click" Background="#29324A" Margin="0,0,8,0" />
                <Button x:Name="HeaderConclusionsButton" Content="Conclusions" Click="HeaderConclusionsButton_Click" Background="#29324A" Margin="0,0,8,0" IsEnabled="False" ToolTip="Record data before opening conclusions." />
                <Button x:Name="SettingsButton" Content="⚙" Click="SettingsButton_Click" Background="#29324A" Width="46" Padding="12,10" ToolTip="Settings" />
            </StackPanel>
        </Grid>

        <Grid x:Name="MetricsChrome" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Session" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="StatusText" Text="Idle" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="SessionTimeText" Text="0.0 s" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Attempts" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AttemptsText" Text="0" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="EventsText" Text="0 tracked" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Clean rate" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="PerfectRateText" Text="0%" Style="{StaticResource MetricValue}" Foreground="{StaticResource Accent2Brush}" />
                    <TextBlock x:Name="PerfectDetailText" Text="0 clean" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Avg counter delay" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AvgDelayText" Text="0.0 ms" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="SpreadText" Text="stdev 0.0 ms" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="7-day aggregate" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="WeekRateText" Text="0%" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="WeekDetailText" Text="0 attempts" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="MainChrome" Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.05*" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Coaching" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="FocusComboBox" Grid.Column="1" SelectedIndex="0" Margin="14,0,12,0" ToolTip="Choose what this short session should judge most strongly." SelectionChanged="FocusComboBox_SelectionChanged">
                                <ComboBoxItem Content="Overall" />
                                <ComboBoxItem Content="Stop before shot" />
                                <ComboBoxItem Content="Fast clean shot" />
                                <ComboBoxItem Content="A&gt;D only" />
                                <ComboBoxItem Content="D&gt;A only" />
                                <ComboBoxItem Content="Mouse control" />
                            </ComboBox>
                            <TextBlock x:Name="FocusFeedbackText" Grid.Column="2" Text="Pick a focus before starting to get more specific advice." Style="{StaticResource Muted}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock x:Name="TipText" Text="Start a session, strafe A/D, counter-strafe with the opposite key, move/correct your mouse, then click. Tips appear after a few attempts." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        <TextBlock x:Name="LatestAttemptText" Text="Latest: waiting for first attempt." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <TextBlock x:Name="DirectionWeaknessText" Text="Direction compare: waiting for both directions." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <TextBlock x:Name="QualityScoreText" Text="Quality score: shows total and max category points after attempts." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <TextBlock x:Name="PracticePrescriptionText" Text="Practice prescription appears after a short session." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button x:Name="OpenConclusionsButton" Grid.Column="1" Content="Conclusions" Click="OpenConclusionsButton_Click" Background="#29324A" VerticalAlignment="Center" IsEnabled="False" ToolTip="Record at least one included attempt before opening conclusions." />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Recent counter-strafe attempts" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Only click-confirmed counter-strafe attempts are shown. Click a row to highlight that trace." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>

                    <WrapPanel x:Name="AttemptFilterPanel" Grid.Row="1" Margin="0,0,0,8">
                        <CheckBox x:Name="ShowIncludedAttemptsCheckBox" Content="Show active" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                        <CheckBox x:Name="ShowFilteredAttemptsCheckBox" Content="Show unchecked" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                        <CheckBox x:Name="ShowPerfectCheckBox" Content="Clean" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                        <CheckBox x:Name="ShowOverlapCheckBox" Content="Overlap" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                        <CheckBox x:Name="ShowLateCheckBox" Content="Held / slow" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                        <CheckBox x:Name="ShowEarlyClickCheckBox" Content="Clicked early" IsChecked="True" Checked="AttemptFilter_Changed" Unchecked="AttemptFilter_Changed" />
                    </WrapPanel>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="No-shot movements are hidden from this list and excluded from reporting. Use the checkbox to exclude warmups, accidental shots, or attempts that are not useful for analysis." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                        <StackPanel Visibility="Collapsed">
                            <CheckBox x:Name="AutoTagJigglesCheckBox" IsChecked="True" />
                            <CheckBox x:Name="ExcludeJigglesCheckBox" IsChecked="True" />
                            <CheckBox x:Name="HideJigglesCheckBox" />
                            <TextBox x:Name="JiggleAgeBox" Text="260" />
                            <TextBox x:Name="JiggleMouseBox" Text="0.08" />
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="AttemptsGrid" Grid.Row="3" IsReadOnly="False" SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="AttemptsGrid_SelectionChanged" KeyDown="AttemptsGrid_KeyDown">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn x:Name="UseColumn" Header="Use" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="AttemptIncludeCheckBox_Changed" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Name="IndexColumn" Header="#" Binding="{Binding Index}" Width="48" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="DirectionColumn" Header="Direction" Binding="{Binding Direction}" Width="105" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="CounterDelayColumn" Header="Counter delay" Binding="{Binding CounterDelayLabel}" Width="120" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="ClickDelayColumn" Header="Click delay" Binding="{Binding ClickLabel}" Width="140" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="MistakesColumn" Header="Mistakes" Binding="{Binding MistakeLabel}" Width="135" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="ResultColumn" Header="Result" Binding="{Binding ResultLabel}" Width="110" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="WhatHappenedColumn" Header="What happened" Binding="{Binding Diagnosis}" Width="*" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mouse trace overlay" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Every trace starts at the counter-key press and ends at the first M1 click. Selected row is drawn brighter." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,6">
                                <CheckBox x:Name="ShowUniqueLinesCheckBox" Content="Unique lines" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                                <CheckBox x:Name="ShowAverageLineCheckBox" Content="Average" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                                <CheckBox x:Name="ShowClickMarkersCheckBox" Content="Click dots" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                            </WrapPanel>
                            <WrapPanel HorizontalAlignment="Right">
                                <TextBlock Text="traces" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="Maximum number of recent included attempts drawn in the overlay." />
                                <TextBox x:Name="TraceCountBox" Text="24" Width="52" Margin="0,0,10,0" ToolTip="Maximum number of recent included attempts drawn in the overlay." />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                        <Grid>
                            <Canvas x:Name="TraceCanvas" Background="#08101E" MouseWheel="TraceCanvas_MouseWheel" MouseLeftButtonDown="TraceCanvas_MouseLeftButtonDown" MouseLeftButtonUp="TraceCanvas_MouseLeftButtonUp" MouseMove="TraceCanvas_MouseMove" MouseLeave="TraceCanvas_MouseLeave" />
                            <Button Content="Reset" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="12,6" Background="#29324A" Click="TraceZoomResetButton_Click" ToolTip="Reset mouse trace zoom and pan" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TraceStatsText" Grid.Row="2" Text="No mouse trace yet." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />

                    <Border Grid.Row="3" Background="#0B1426" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="68" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Selected attempt key replay" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="Select an attempt, then replay the A/D release, opposite-key press, and M1 click in slow motion." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button Content="1x" Tag="1" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ReplaySpeedButton_Click" ToolTip="Replay at normal speed" />
                                    <Button Content="5x slow" Tag="5" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ReplaySpeedButton_Click" ToolTip="Replay five times slower" />
                                    <Button Content="10x slow" Tag="10" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ReplaySpeedButton_Click" ToolTip="Replay ten times slower" />
                                    <Button Content="Pause" Height="30" Padding="14,6" Background="#29324A" Click="ReplayStopButton_Click" />
                                </WrapPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="KeyABox" Grid.Column="0" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="A" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="KeyAStateText" Text="up" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="KeyDBox" Grid.Column="1" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="12" Margin="4,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="D" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="KeyDStateText" Text="up" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="KeyM1Box" Grid.Column="2" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="12" Margin="8,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="M1" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="KeyM1StateText" Text="up" Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <Canvas x:Name="ReplayTimelineCanvas" Background="#08101E" SizeChanged="ReplayTimeline_SizeChanged" />
                            </Border>

                            <TextBlock x:Name="ReplayGuidanceText" Grid.Row="3" Text="Target timing tips appear here when you select an attempt." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            <TextBlock x:Name="ReplayStatusText" Grid.Row="4" Text="Select a click-confirmed attempt to replay its key timing." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="ModeHostBorder" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100" Background="{StaticResource WindowBgBrush}" Visibility="Collapsed">
            <ContentControl x:Name="ModeHost" />
        </Border>
    </Grid>
</Window>
