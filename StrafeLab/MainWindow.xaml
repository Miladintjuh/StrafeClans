<Window x:Class="StrafeLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StrafeLab" Height="940" Width="1500" MinHeight="820" MinWidth="1220">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SmallLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#10172A" />
            <Setter Property="AlternatingRowBackground" Value="#131B30" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182139" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="StrafeLab" FontSize="34" FontWeight="Bold" />
                <TextBlock Text="Local A/D + mouse timing analyzer for counter-strafe practice" Style="{StaticResource Muted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="StartButton" Content="Start Session" Click="StartButton_Click" Margin="0,0,8,0" />
                <Button x:Name="StopButton" Content="Stop + Save" Click="StopButton_Click" Background="#29324A" Margin="0,0,8,0" />
                <Button Content="Open Data Folder" Click="OpenFolderButton_Click" Background="#29324A" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Session" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="StatusText" Text="Idle" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="SessionTimeText" Text="0.0 s" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Attempts" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AttemptsText" Text="0" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="EventsText" Text="0 events" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Perfect rate" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="PerfectRateText" Text="0%" Style="{StaticResource MetricValue}" Foreground="{StaticResource Accent2Brush}" />
                    <TextBlock x:Name="PerfectDetailText" Text="0 perfect" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Avg counter delay" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AvgDelayText" Text="0.0 ms" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="SpreadText" Text="stdev 0.0 ms" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="7-day aggregate" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="WeekRateText" Text="0%" Style="{StaticResource MetricValue}" />
                    <TextBlock x:Name="WeekDetailText" Text="0 attempts" Style="{StaticResource Muted}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.05*" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="112" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Coaching" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="TipText" Text="Start a session, strafe A/D, counter-strafe, move the mouse, and click. Tips appear after a few attempts." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,18,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0">
                        <TextBlock Text="Counter min" Style="{StaticResource SmallLabel}" />
                        <TextBox x:Name="CounterMinBox" Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="6,0">
                        <TextBlock Text="Counter max" Style="{StaticResource SmallLabel}" />
                        <TextBox x:Name="CounterMaxBox" Text="80" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="6,0">
                        <TextBlock Text="Click min" Style="{StaticResource SmallLabel}" />
                        <TextBox x:Name="ClickMinBox" Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="6,0">
                        <TextBlock Text="Click max" Style="{StaticResource SmallLabel}" />
                        <TextBox x:Name="ClickMaxBox" Text="160" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Game calibration" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Enter your in-game values to convert raw mouse counts into estimated degrees and cm/360." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,8" />
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="DPI" Style="{StaticResource SmallLabel}" />
                            <TextBox x:Name="DpiBox" Text="800" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0">
                            <TextBlock Text="Sens" Style="{StaticResource SmallLabel}" />
                            <TextBox x:Name="SensBox" Text="1.0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0">
                            <TextBlock Text="Yaw" Style="{StaticResource SmallLabel}" />
                            <TextBox x:Name="YawBox" Text="0.022" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="6,0">
                            <TextBlock Text="Pitch" Style="{StaticResource SmallLabel}" />
                            <TextBox x:Name="PitchBox" Text="0.022" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="6,0,0,0">
                            <TextBlock Text="Mult" Style="{StaticResource SmallLabel}" />
                            <TextBox x:Name="MultiplierBox" Text="1.0" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock x:Name="Cm360Text" Text="cm/360 unavailable" Style="{StaticResource Muted}" Margin="0,0,18,0" />
                        <TextBlock x:Name="DegreesPerCountText" Text="0.000000 deg/count X" Style="{StaticResource Muted}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent counter-strafe attempts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <DataGrid x:Name="AttemptsGrid" Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48" />
                            <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="105" />
                            <DataGridTextColumn Header="Counter delay" Binding="{Binding CounterDelayLabel}" Width="120" />
                            <DataGridTextColumn Header="Click after counter" Binding="{Binding ClickLabel}" Width="140" />
                            <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="110" />
                            <DataGridTextColumn Header="Aim delta" Binding="{Binding AimDeltaLabel}" Width="190" />
                            <DataGridTextColumn Header="Mouse path" Binding="{Binding PathLabel}" Width="150" />
                            <DataGridTextColumn Header="Trace pts" Binding="{Binding TracePointsLabel}" Width="85" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" />
                    <RowDefinition Height="0.9*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Mouse trace overlay" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Every trace starts at the counter-key press and ends at the first M1 click." Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ShowUniqueLinesCheckBox" Content="Unique lines" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                                <CheckBox x:Name="ShowAverageLineCheckBox" Content="Average" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                                <CheckBox x:Name="ShowClickMarkersCheckBox" Content="Click dots" IsChecked="True" Checked="TraceOption_Changed" Unchecked="TraceOption_Changed" />
                                <TextBox x:Name="TraceCountBox" Text="24" Width="52" Margin="0,0,0,0" />
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                            <Canvas x:Name="TraceCanvas" Background="#08101E" />
                        </Border>
                        <TextBlock x:Name="TraceStatsText" Grid.Row="2" Text="No mouse trace yet." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Recent input edges" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Tracks A, D, M1, M2, and raw mouse movement only during visible sessions. Data stays local." Style="{StaticResource Muted}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ListBox x:Name="EventsList" Grid.Row="1" DisplayMemberPath="Label" Background="#10172A" BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextBrush}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
