<UserControl x:Class="StrafeLab.ShowLastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBgBrush}"
             Foreground="{StaticResource TextBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Show last attempt" FontSize="30" FontWeight="Bold" />
                <TextBlock x:Name="StatusText" Text="Listening for the next click-confirmed counter-strafe…" Foreground="{StaticResource MutedTextBrush}" FontSize="14" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Content="Back" Click="BackButton_Click" Background="#29324A" Padding="16,10" />
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="100" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Attempt key replay" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="1x" Tag="1" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ShowLastReplaySpeedButton_Click" />
                        <Button Content="5x slow" Tag="5" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ShowLastReplaySpeedButton_Click" />
                        <Button Content="10x slow" Tag="10" Height="30" Padding="14,6" Margin="0,0,6,0" Click="ShowLastReplaySpeedButton_Click" />
                        <TextBox x:Name="ShowLastReplayCustomSlowBox" Text="5" Width="48" Height="30" Margin="0,0,6,0" ToolTip="Custom slow factor. Example: 8 means the replay takes 8x longer." />
                        <Button Content="Slow (x)" Height="30" Padding="12,6" Margin="0,0,6,0" Click="ShowLastReplayCustomSlowButton_Click" />
                        <Button Content="Pause" Height="30" Padding="14,6" Background="#29324A" Click="ShowLastReplayPauseButton_Click" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,10,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="KeyABox" Grid.Column="0" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center"><TextBlock Text="A" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" /><TextBlock x:Name="KeyAStateText" Text="up" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" /></StackPanel>
                    </Border>
                    <Border x:Name="KeyDBox" Grid.Column="1" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="10" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center"><TextBlock Text="D" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" /><TextBlock x:Name="KeyDStateText" Text="up" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" /></StackPanel>
                    </Border>
                    <Border x:Name="KeyM1Box" Grid.Column="2" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="10" Margin="8,0,0,0">
                        <StackPanel HorizontalAlignment="Center"><TextBlock Text="M1" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" /><TextBlock x:Name="KeyM1StateText" Text="up" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" /></StackPanel>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Canvas x:Name="ReplayCanvas" Background="#08101E" SizeChanged="ReplayCanvas_SizeChanged" />
                </Border>
                <TextBlock x:Name="ReplayText" Grid.Row="3" Text="The next attempt replay will appear here." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Mouse trace overlay" FontSize="18" FontWeight="SemiBold" />
                    <Border Grid.Row="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" ClipToBounds="True" Margin="0,10,0,8">
                        <Canvas x:Name="TraceCanvas" Background="#08101E" SizeChanged="TraceCanvas_SizeChanged" />
                    </Border>
                    <TextBlock x:Name="TraceText" Grid.Row="2" Text="Mouse path appears when the attempt has movement data." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12" TextElement.Foreground="{StaticResource TextBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Attempt details" Foreground="{StaticResource TextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBlock x:Name="DirectionText" Foreground="{StaticResource TextBrush}" Grid.Row="1" Text="Direction: -" Margin="0,4" />
                    <TextBlock x:Name="CounterDelayText" Foreground="{StaticResource TextBrush}" Grid.Row="2" Text="Key wait: -" Margin="0,4" />
                    <TextBlock x:Name="ClickDelayText" Foreground="{StaticResource TextBrush}" Grid.Row="3" Text="Click wait: -" Margin="0,4" />
                    <TextBlock x:Name="TraceDetailText" Foreground="{StaticResource TextBrush}" Grid.Row="4" Text="Trace: -" Margin="0,4" />
                    <TextBlock x:Name="MistakeText" Foreground="{StaticResource TextBrush}" Grid.Row="5" Text="Mistakes: -" Margin="0,4" />
                    <TextBlock x:Name="ResultText" Foreground="{StaticResource TextBrush}" Grid.Row="6" Text="Result: -" Margin="0,4" />
                    <TextBlock x:Name="WhatHappenedText" Foreground="{StaticResource TextBrush}" Grid.Row="7" Text="What happened: waiting for attempt." TextWrapping="Wrap" Margin="0,4,0,12" />
                    <Button Grid.Row="8" Content="Solution" Click="SolutionButton_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="18,10" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="SolutionOverlay" Grid.RowSpan="4" Background="#AA000000" Visibility="Collapsed">
            <Border Width="600" MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#10182C" BorderBrush="{StaticResource Accent2Brush}" BorderThickness="2" CornerRadius="22" Padding="22">
                <StackPanel>
                    <TextBlock x:Name="SolutionTitle" Text="How to fix it" FontSize="26" FontWeight="Bold" />
                    <TextBlock x:Name="SolutionBody" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="15" Margin="0,12,0,18" />
                    <Canvas x:Name="SolutionCanvas" Height="130" Background="#08101E" Margin="0,0,0,18" />
                    <Button Content="OK" Click="CloseSolutionButton_Click" HorizontalAlignment="Right" Padding="18,10" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
