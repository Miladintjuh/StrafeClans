<UserControl x:Class="StrafeLab.ConclusionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Conclusions" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Text="Included attempt analysis." Style="{StaticResource Muted}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Back" Click="BackButton_Click" Background="#29324A" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <UniformGrid Columns="5">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Attempts" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="AttemptsText" FontSize="32" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Clean rate" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="CleanRateText" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Moving shots" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="MovingText" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Avg counter delay" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="DelayText" FontSize="32" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Quality score" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="QualityText" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Accent2Brush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TabControl x:Name="ConclusionsTabs" Margin="8">
                    <TabItem Header="Timing">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="360" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="TimingCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <TextBlock x:Name="TimingInsightText" Grid.Row="1" TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,12,0,0" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Direction compare">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="360" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Column="0" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Margin="0,0,8,0">
                                <Canvas x:Name="DirectionCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <Border Grid.Column="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Margin="8,0,0,0">
                                <Canvas x:Name="ResultCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <TextBlock x:Name="DirectionInsightText" Grid.Row="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,12,0,0" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Mistakes">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="360" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Column="0" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Margin="0,0,8,0">
                                <Canvas x:Name="MistakesCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <Border Grid.Column="1" Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Margin="8,0,0,0">
                                <Canvas x:Name="MetricsCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <TextBlock x:Name="MistakesInsightText" Grid.Row="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,12,0,0" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Mouse / aim">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="360" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Background="#08101E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                                <Canvas x:Name="AimCanvas" Background="#08101E" SizeChanged="Canvas_SizeChanged" />
                            </Border>
                            <TextBlock x:Name="AimInsightText" Grid.Row="1" TextWrapping="Wrap" Style="{StaticResource Muted}" Margin="0,12,0,0" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Score / fix">
                        <Border Style="{StaticResource Card}" Margin="10">
                            <TextBlock x:Name="ScoreBreakdownText" TextWrapping="Wrap" FontSize="15" LineHeight="22" />
                        </Border>
                    </TabItem>
                    <TabItem Header="Practice plan">
                        <Border Style="{StaticResource Card}" Margin="10">
                            <TextBlock x:Name="PracticeText" TextWrapping="Wrap" FontSize="15" LineHeight="22" />
                        </Border>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
